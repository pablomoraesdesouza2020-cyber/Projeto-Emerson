import { useState } from 'react';

import {
  FlatList,
  Image,
  Modal,
  SafeAreaView,
  ScrollView,
  StyleSheet,
  Text, TextInput, TouchableOpacity,
  View
} from 'react-native';

import Logo from './assets/tadc.webp';

import MiniLogo from './assets/minilogo.png';

// --- Componente de Item da Lista (Uso de Props) ---
const ItemCompra = ({ dado }) => (
  <View style={styles.itemContainer}>
    <Text style={styles.itemTexto}>
      {dado.qtd} {dado.unidade} - {dado.nome}
    </Text>
  </View>
);

export default function App() {

  // --- Estados (useState) ---
  const [produto, setProduto] = useState('');
  const [quantidade, setQuantidade] = useState('');
  const [unidade, setUnidade] = useState('вӯҗ');
  const [lista, setLista] = useState([]);
  const [modalVisivel, setModalVisivel] = useState(false);

  // Lista de unidades disponГӯveis
  const opcoesUnidade = ['0вӯҗ', '1вӯҗ', '2вӯҗ', '3вӯҗ', '4вӯҗ', '5вӯҗ'];

    const funcaoInserir = () => {
    const novoItem = {
        id: Date.now().toString(),
        nome: produto, // produto estГЎ vazio
        qtd: quantidade,
        unidade: unidade,
    };

    setLista([...lista, novoItem]);
    setProduto('');
    setQuantidade('');
};


// --- FunГ§ГЈo para Selecionar Unidade ---
const selecionarUnidade = (item) => {
  setUnidade(item);
  setModalVisivel(false);
};

return (
  <SafeAreaView style={styles.container}>
    
    <View style={styles.caixaInput}>
      <Image source={Logo} style={styles.logo} />

      <Image source={MiniLogo} style={styles.miniLogo} />

      <View style={styles.linha}>
        <TextInput
          style={[styles.input, { flex: 1, marginRight: 10 }]}
          placeholder="Deixe seu comentario"
          value={quantidade}
          onChangeText={setQuantidade}
        />

<TouchableOpacity
  style={styles.botaoUnidade}
  onPress={() => setModalVisivel(true)}
>
  <Text>{unidade} </Text>
</TouchableOpacity>
</View>

<TouchableOpacity style={styles.botaoAdd} onPress={funcaoInserir}>
  <Text style={styles.textoBotao}>ADICIONAR</Text>
</TouchableOpacity>
</View>


<FlatList
  data={lista}
  keyExtractor={(item) => item.id}
  renderItem={({ item }) => <ItemCompra dado={item} />}
/>

{/* --- Modal que funciona como Menu Suspenso --- */}
<Modal visible={modalVisivel} transparent={true} animationType="fade">
  <TouchableOpacity
    style={styles.fundoModal}
    onPress={() => setModalVisivel(false)}
  >
    <View style={styles.menuModal}>
      <ScrollView>
        {opcoesUnidade.map((un) => (
          <TouchableOpacity
            key={un}
            style={styles.opcao}
            onPress={() => selecionarUnidade(un)}
          >
            <Text style={styles.textoOpcao}>{un}</Text>
          </TouchableOpacity>
        ))}
      </ScrollView>
    </View>
  </TouchableOpacity>
</Modal>
</SafeAreaView> 
);
}


